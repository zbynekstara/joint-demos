{
    "aws_cloudwatch": {
        "name": "AWS CloudWatch",
        "icon": "aws_cloudwatch.svg",
        "actions": [
            {
                "id": "put_metric_alarm",
                "name": "Create/Update Alarm",
                "description": "Creates or updates a CloudWatch alarm.",
                "data": {
                    "alarm_name": {
                        "name": "Alarm Name",
                        "type": "string",
                        "description": "Unique name for the alarm."
                    },
                    "namespace": {
                        "name": "Namespace",
                        "type": "string",
                        "description": "Metric namespace (e.g., AWS/EC2)."
                    },
                    "metric_name": {
                        "name": "Metric Name",
                        "type": "string",
                        "description": "Metric to alarm on."
                    },
                    "dimensions": {
                        "name": "Dimensions",
                        "type": "array",
                        "description": "Array of { Name, Value } pairs."
                    },
                    "statistic": {
                        "name": "Statistic",
                        "type": "string",
                        "description": "Sample statistic (Average|Sum|Minimum|Maximum|SampleCount)."
                    },
                    "period": {
                        "name": "Period (s)",
                        "type": "number",
                        "description": "Evaluation period in seconds."
                    },
                    "evaluation_periods": {
                        "name": "Evaluation Periods",
                        "type": "number",
                        "description": "Number of periods to evaluate."
                    },
                    "threshold": {
                        "name": "Threshold",
                        "type": "number",
                        "description": "Alarm threshold value."
                    },
                    "comparison_operator": {
                        "name": "Comparison Operator",
                        "type": "string",
                        "description": "GreaterThanOrEqualToThreshold|GreaterThanThreshold|LessThanThreshold|LessThanOrEqualToThreshold."
                    },
                    "treat_missing_data": {
                        "name": "Treat Missing Data",
                        "type": "string",
                        "description": "breaching|notBreaching|ignore|missing."
                    },
                    "alarm_actions": {
                        "name": "Alarm Actions",
                        "type": "array",
                        "description": "List of SNS topic ARNs to notify on ALARM."
                    },
                    "ok_actions": {
                        "name": "OK Actions",
                        "type": "array",
                        "description": "List of SNS topic ARNs to notify on OK."
                    }
                }
            },
            {
                "id": "set_alarm_state",
                "name": "Set Alarm State",
                "description": "Manually sets the state of an alarm (testing).",
                "data": {
                    "alarm_name": {
                        "name": "Alarm Name",
                        "type": "string",
                        "description": "Target alarm name."
                    },
                    "state_value": {
                        "name": "State Value",
                        "type": "string",
                        "description": "OK|ALARM|INSUFFICIENT_DATA."
                    },
                    "state_reason": {
                        "name": "State Reason",
                        "type": "string",
                        "description": "Human-readable reason for state change."
                    }
                }
            }
        ]
    },
