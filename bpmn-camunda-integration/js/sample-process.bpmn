        <bpmn:serviceTask id="id__41797568-5a01-4463-8104-f39bfc7d3996" name="HTTP Request"
            zeebe:modelerTemplate="io.camunda.connectors.HttpJson.v2"
            zeebe:modelerTemplateVersion="12">
            <bpmn:extensionElements>
                <zeebe:taskDefinition xmlns:zeebe="http://camunda.org/schema/zeebe/1.0"
                    type="io.camunda:http-json:1" retries="3" />
                <zeebe:ioMapping xmlns:zeebe="http://camunda.org/schema/zeebe/1.0">
                    <zeebe:input source="=&quot;noAuth&quot;" target="authentication.type" />
                    <zeebe:input source="=&quot;POST&quot;" target="method" />
                    <zeebe:input source="=&quot;https://api.openai.com/v1/responses&quot;"
                        target="url" />
                    <zeebe:input
                        source="={&#10;&quot;Authorization&quot;: &quot;Bearer YOUR_OPENAI_API_KEY&quot;&#10;}"
                        target="headers" />
                    <zeebe:input
                        source="={&#10;&quot;model&quot;: &quot;gpt-5.2&quot;,&#10;&quot;input&quot;: &quot;Create an HTML report from the EDGAR JSON below. Extract only the most interesting data. Make sure the report is standalone and does not require any manual updates. It should work as-is when opened in the browser.\n\n&quot; + string(edgar)&#10;}"
                        target="body" />
                    <zeebe:input source="=false" target="storeResponse" />
                    <zeebe:input source="=240" target="connectionTimeoutInSeconds" />
                    <zeebe:input source="=240" target="readTimeoutInSeconds" />
                    <zeebe:input source="=0" target="writeTimeoutInSeconds" />
                    <zeebe:input source="=false" target="ignoreNullValues" />
                </zeebe:ioMapping>
                <zeebe:taskHeaders xmlns:zeebe="http://camunda.org/schema/zeebe/1.0">
                    <zeebe:header key="elementTemplateVersion" value="12" />
                    <zeebe:header key="elementTemplateId" value="io.camunda.connectors.HttpJson.v2" />
                    <zeebe:header key="resultVariable" value="" />
                    <zeebe:header key="resultExpression"
                        value="{&#10;  reportHtml: response.body.output[1].content[1].text,&#10;inputTokens: response.body.usage.input_tokens,&#10;outputTokens: response.body.usage.output_tokens&#10;}" />
                    <zeebe:header key="errorExpression" value="" />
                    <zeebe:header key="retryBackoff" value="PT0S" />
                </zeebe:taskHeaders>
            </bpmn:extensionElements>
            <bpmn:incoming>id__bd220018-a05c-4ae4-a36e-b1bbed7a7f9b</bpmn:incoming>
            <bpmn:outgoing>id__094dcc96-f31f-46ad-b836-7f9a95014bbb</bpmn:outgoing>
